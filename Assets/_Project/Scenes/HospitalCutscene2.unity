  dialogueUI: {fileID: 549297507}
  lines:
  - 'Sawyer: Lily! I''m here.'
  - 'Lily: Sawyer?'
  - 'Lily: Sawyer!!!'
  - 'Lily: It''s so dark here. This room is scary...'
  - 'Sawyer: It''s OK Lily, I''m here.'
  - 'Lily: Sawyer...'
  - 'Lily: Promise me you won''t leave me...'
  - 'Sawyer: I Promise.'
  - 'Lily: Ok...'
  - 'Sawyer: C''mon. Let''s get outta here.'
